<page>
    <problem workspace="1.5in">
        <statement>
            <p>
                (6 points) Show your work in the space below and put your answer in the boxes.

                Find the <m>LU</m> factorization for the following matrix

                <me>A = \begin{pmatrix}1 \amp 2 \amp 1 \amp 3 \\ 2 \amp 5 \amp 2 \amp 4 \\ 3 \amp 8 \amp 3 \amp 7\end{pmatrix}.</me>

                <me>L = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a \amp a \amp a \amp a \\ b  \\ c \\d \\ d \\ d \amp d \ amp d \end{bmatrix}$}$ }</me>

                <me>U = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a \amp a \amp a \amp a \\ b  \\ c \\d \\ d \\ d \amp d \ amp d \end{bmatrix}$}$ }</me>
            </p>
            
        </statement>
        <answer>
            <p>
                <me>L = \begin{pmatrix} 1 \amp 0 \amp 0 \\ 2 \amp 1 \amp 0 \\ 3 \amp 2 \amp 1\end{pmatrix}</me>
                <me>U = \begin{pmatrix} 1 \amp 2 \amp 1 \amp 3 \\ 0 \amp 1 \amp 0 \amp -2 \\ 0 \amp 0  \amp 0 \amp 2\end{pmatrix}</me>
            </p>
        </answer>
        <solution>
            <p>
                Solution text 
            </p>
        </solution>
    </problem>
</page>


