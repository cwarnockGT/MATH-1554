<page>
    <problem workspace="1.5in">
        <statement>
            <p> (6 points) <m> \textbf{Show your work for part (b) on this page.}</m>
                <md></md>
            
                Use the following Markov chain diagram to answer the questions.
                <md></md>
                (a) Find the stochastic matrix <m>P</m> of the Markov chain.

                <md></md>
                (b) Find the unique steady state probability vector <m>\vec{q}</m> of <m>P</m>
                <md></md>

                (c) If <m>\vec{x} = \begin{pmatrix}10 \\ 18 \end{pmatrix}</m>, find the limit <m>l</m> of the sequence of vectors <m>P^k \vec{x_0}</m> as <m>k</m> tend to infinity.
                <md></md>
                

                <figure xml:id="markov-two-state">
  <image>
    <latex-image>
\begin{tikzpicture}
\begin{scope}[->,>=stealth',shorten >=1pt,auto,node distance=3cm,
  thick,main node/.style={circle,fill=blue!20,draw,font=\sffamily\Large\bfseries}]
   \node[main node] (1) {A};
   \node[main node] (2) [right of=1] {B};

   \path[every node/.style={font=\sffamily\small}]
      (1) edge [bend right] node[below] {0.3} (2)
          edge [loop above] node {0.7} (1)
      (2) edge node [above] {0.4} (1)
          edge [loop above] node {0.6} (2);
\end{scope}
\end{tikzpicture}
    </latex-image>
  </image>
</figure>

                <md>P = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a \amp a \amp a \amp a \\ b  \\ c \end{bmatrix}$}$ }</md>
                <md>\vec{q} = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a \\ b  \\ c \end{bmatrix}$}$ }</md>
                <md>\vec{l} = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a \\ b  \\ c \end{bmatrix}$}$ }</md>
            </p>
            
        </statement>
        <answer>
            <p>
                <md>P = \begin{bmatrix}  0.7 \amp 0.4 \\ 0.3 \amp 0.6 \end{bmatrix}</md>

                <md>\vec{q} = \begin{bmatrix}  \frac{4}{7} \\ \frac{3}{7} \end{bmatrix}</md>

                <md>\vec{l} = \begin{bmatrix}  16 \\ 12 \end{bmatrix}</md>
            </p>
        </answer>
        <solution>
            <p>
                Solution text 
            </p>
        </solution>
    </problem>
</page>

<page>
    <problem workspace="1.5in">
        <statement>
            <p>
                (4 points) Show your work in the space below and put your answer in the boxes.

                Let

                <me>W = \left\{\begin{bmatrix} x_1 \\ x_2 \\ x_3 \\ x_4 \end{bmatrix} \in \mathbb{R}^4 \ : \ x_1 + 2x_2 - x_3 + 3x_4 = 0 \right\}.</me>
                Find a basis for <m>W</m> and state <m>\dim(W)</m>


                <md>
                    \text{basis for W} = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a \amp a \amp a \amp a \amp a \amp a \\ b  \\ c  \\ d \\ e \\ f \\ g \\ h\end{bmatrix}$}$ }

                </md>

                <md>
                    \dim(W) = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a \\ b \end{bmatrix}$}$ }
                </md>
                
                
            </p>
            
        </statement>
        <answer>
            <p>
                <me>\text{basis for W} = \left\{ \begin{bmatrix} -2 \\ 1 \\ 0 \\ 0 \end{bmatrix}, \begin{bmatrix} 1 \\ 0 \\ 1 \\ 0 \end{bmatrix}, \begin{bmatrix} -3 \\ 0 \\ 0 \\ 1 \end{bmatrix} \right\}</me>
                <me>\dim(W) = 3</me>
            </p>
        </answer>
        <solution>
            <p>
                Solution text 
            </p>
        </solution>
    </problem>
</page>

<page>
    <problem workspace="1.5in">
        <statement>
            <p>
                (6 points) Show your work in the space below and put your answer in the boxes.

                Find the <m>LU</m> factorizations for the following matrix

                <md>
                    A = \begin{pmatrix} 1 \amp 2 \amp 1 \amp 3 \\ 2 \amp 5 \amp 2 \amp 4 \\ 3 \amp 4 \amp 3 \amp7 \end{pmatrix}
                </md>
                
                <md>
                    L = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a  \\ b  \\ c  \\ d\end{bmatrix}$}$ }
                </md>
                <md>
                    U = \framebox{$\phantom{$\begin{bmatrix} a \amp a \amp a \amp a  \\ b  \\ c  \\ d\end{bmatrix}$}$ }
                </md>
                
            </p>
            
        </statement>
        <answer>
            <p>
                <me>L = \begin{bmatrix} 1 \amp 0 \amp 0 \\ 2 \amp 1 \amp 0 \\ 3 \amp -2 \amp 1 \end{bmatrix}</me>
                <me>U = \begin{bmatrix} 1 \amp 2 \amp 1 \amp 3 \\ 0 \amp 1 \amp 0 \amp -2 \\ 0 \amp 0 \amp 0 \amp -6 \end{bmatrix}</me>
            </p>
        </answer>
        <solution>
            <p>
                Solution text 
            </p>
        </solution>
    </problem>
</page>



