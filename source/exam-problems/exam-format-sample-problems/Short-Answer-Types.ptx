<!-- Short Answer with Graphing -->
<problem workspace="true">
    <statement>
        <p>
            (4 points) Drawing Problem. Uses Tikz.
        </p>
        <image xml:id="img-grid-exam1sp26" width="70%">
            <shortdescription>
                Two square grids with horizontal and vertical axes spanning from -4 to 4.
            </shortdescription>
            <latex-image>
            <preamble>
            </preamble>
            <tex>
                \begin{tikzpicture}[scale=.5]
                \draw[help lines] (-4, -4) grid (4, 4);
                \draw[thick, -&gt;] (-4, 0) -- (4, 0);
                \draw[thick, -&gt;] (0, -4) -- (0, 4);
                \node[overlay, above] at (0, 4) {(a) a vector $\vec b$};
                \node[right] at (4, 0) {$x_1$};
                \node[right] at (0, 4) {$x_2$};                
                \end{tikzpicture}\qquad
                \begin{tikzpicture}[scale=.5]
                \draw[help lines] (-4, -4) grid (4, 4);
                \draw[thick, -&gt;] (-4, 0) -- (4, 0);
                \draw[thick, -&gt;] (0, -4) -- (0, 4);
                \node[above] at (0, 4) {(b) set of solutions};
                \node[right] at (4, 0) {$x_1$};
                \node[right] at (0, 4) {$x_2$};  
                \end{tikzpicture}
            </tex>
            </latex-image>
        </image>
    </statement>
    <answer>
        <p>
            Could include drawing in solution or just describe.
        </p>
    </answer>
    <solution>
        <p>
            Description of Drawing or Picture in Tikz
        </p>
    </solution>
</problem>