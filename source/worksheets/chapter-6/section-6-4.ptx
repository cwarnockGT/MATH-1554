<?xml version="1.0" encoding="UTF-8"?>
<handout>
  <title>Worksheet 6.4, The Gram–Schmidt Process</title>

  <ul marker="">

    <!-- Problem 1 -->
    <li workspace="2in">
      <p>(1) &#160; Compute the QR decomposition of 
        <m>
        A =
        \begin{pmatrix}
          1 &amp; 5 \\
          3 &amp; 1 \\
          -2 &amp; 4
        \end{pmatrix}.
        </m>
      </p>
    </li>

    <!-- Problem 2 -->
    <li workspace="2in">
      <p>(2) &#160; Consider the three vectors below.</p>

      <p>
        <me>
        \vec{x}_1 =
        \begin{pmatrix}
          1 \\ 1 \\ 1 \\ 1 \\ 1
        \end{pmatrix},
        \quad
        \vec{x}_2 =
        \begin{pmatrix}
          2 \\ 1 \\ 0 \\ -1 \\ -2
        \end{pmatrix},
        \quad
        \vec{x}_3 =
        \begin{pmatrix}
          4 \\ 1 \\ 1 \\ 1 \\ 4
        \end{pmatrix}
        </me>
      </p>

      <ol marker="(a)">
        <li>
          <p>
            The pair of vectors <m>\vec{x}_1</m> and <m>\vec{x}_2</m> are orthogonal.
            Which other pairs of vectors are orthogonal?
          </p>
        </li>

        <li>
          <p>
            Use the vectors above, in that order, to construct three orthogonal
            vectors using the Gram–Schmidt process.
          </p>
        </li>
      </ol>
    </li>

  </ul>
</handout>